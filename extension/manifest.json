{
  "manifest_version": 3,
  "name": "AppliCache",
  "version": "1.0.0",
  "description": "Save LinkedIn jobs to your AppliCache dashboard.",
  "icons": {
    "16": "applicache_logo.png",
    "32": "applicache_logo.png",
    "48": "applicache_logo.png",
    "128": "applicache_logo.png"
  },
  "permissions": ["storage", "identity"],
  "externally_connectable": {
    "matches": ["http://localhost:5173/*"]
  },
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://*.execute-api.us-east-1.amazonaws.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AppliCache",
    "default_icon": {
      "16": "applicache_logo.png",
      "32": "applicache_logo.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "all_frames": false,
      "match_about_blank": false
    }
  ]
}
